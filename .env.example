# =============================================================================
# Order-Service - Environment Configuration
# =============================================================================
# Copy this file to .env and update the values
# Compatible with TFO-Collector v1.2.1 (OCB-native)
# =============================================================================

# -----------------------------------------------------------------------------
# GENERAL
# -----------------------------------------------------------------------------
TZ=UTC

# -----------------------------------------------------------------------------
# SERVER
# -----------------------------------------------------------------------------
SERVER_PORT=8080
SERVER_READ_TIMEOUT=15s
SERVER_WRITE_TIMEOUT=15s

# -----------------------------------------------------------------------------
# DATABASE (PostgreSQL)
# -----------------------------------------------------------------------------
DB_DRIVER=postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=orders
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_SSL_MODE=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=5m

# -----------------------------------------------------------------------------
# JWT AUTHENTICATION
# -----------------------------------------------------------------------------
JWT_SECRET=your_jwt_secret_here_min_64_chars_recommended
JWT_EXPIRATION=24h
JWT_REFRESH_EXPIRATION=168h
SESSION_SECRET=your_session_secret_here_min_64_chars_recommended

# -----------------------------------------------------------------------------
# RATE LIMITING
# -----------------------------------------------------------------------------
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=1m

# -----------------------------------------------------------------------------
# TELEMETRYFLOW SDK - Core Settings
# Compatible with TFO-Collector v1.2.1
# -----------------------------------------------------------------------------
TELEMETRYFLOW_API_KEY_ID=tfk_your_key_id
TELEMETRYFLOW_API_KEY_SECRET=tfs_your_key_secret
TELEMETRYFLOW_ENDPOINT=localhost:4317
TELEMETRYFLOW_SERVICE_NAME=Order-Service
TELEMETRYFLOW_SERVICE_VERSION=1.2.0
TELEMETRYFLOW_ENVIRONMENT=development
TELEMETRYFLOW_INSECURE=true

# -----------------------------------------------------------------------------
# TELEMETRYFLOW SDK - TFO v2 API Settings (aligned with tfoexporter)
# -----------------------------------------------------------------------------
# Enable TFO v2 API (default: true)
TELEMETRYFLOW_USE_V2_API=true

# Enable v2-only mode - disables v1 endpoints (default: false)
TELEMETRYFLOW_V2_ONLY=false

# -----------------------------------------------------------------------------
# TELEMETRYFLOW SDK - Collector Identity (aligned with tfoidentityextension)
# -----------------------------------------------------------------------------
TELEMETRYFLOW_COLLECTOR_ID=
TELEMETRYFLOW_COLLECTOR_NAME=Order-Service SDK Client
TELEMETRYFLOW_DATACENTER=default

# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------
LOG_LEVEL=info
LOG_FORMAT=json

# -----------------------------------------------------------------------------
# DOCKER COMPOSE - Container Settings
# -----------------------------------------------------------------------------

# PostgreSQL
POSTGRES_VERSION=16-alpine
CONTAINER_POSTGRES=tfo_sdk_postgresql
CONTAINER_IP_POSTGRES=172.152.152.20
PORT_POSTGRES=5432

# API
CONTAINER_API=tfo_sdk_restapi
CONTAINER_IP_API=172.152.152.10
PORT=8080

# TFO Collector
TFO_COLLECTOR_VERSION=1.2.1
CONTAINER_OTEL=tfo_sdk_collector
CONTAINER_IP_OTEL=172.152.152.30
PORT_OTEL_GRPC=4317
PORT_OTEL_HTTP=4318
PORT_OTEL_METRICS=8889
PORT_OTEL_HEALTH=13133

# Prometheus
PROMETHEUS_VERSION=v3.4.0
CONTAINER_PROMETHEUS=tfo_sdk_prometheus
CONTAINER_IP_PROMETHEUS=172.152.152.50
PORT_PROMETHEUS=9090

# -----------------------------------------------------------------------------
# DOCKER COMPOSE - TFO Platform Services (platform profile)
# -----------------------------------------------------------------------------
TFO_PLATFORM_VERSION=1.4.0
CONTAINER_TFO_BACKEND=TFO-Platform-Backend
CONTAINER_IP_TFO_BACKEND=172.152.153.10
PORT_BACKEND=3000
CONTAINER_TFO_VIZ=TFO-Platform-Viz
CONTAINER_IP_TFO_VIZ=172.152.153.15
PORT_FRONTEND=8080

# Platform PostgreSQL
TFO_POSTGRES_USERNAME=tfo_admin
TFO_POSTGRES_PASSWORD=telemetryflow123
TFO_POSTGRES_DB=telemetryflow_db
CONTAINER_TFO_POSTGRES=TFO-Platform-PostgreSQL
CONTAINER_IP_TFO_POSTGRES=172.152.153.20
PORT_TFO_PLATFORM_POSTGRES=5433

# ClickHouse
CLICKHOUSE_VERSION=24.12-alpine
CLICKHOUSE_USER=tfo_admin
CLICKHOUSE_PASSWORD=telemetryflow123
CLICKHOUSE_DB=telemetryflow_db
CONTAINER_TFO_CLICKHOUSE=TFO-Platform-ClickHouse
CONTAINER_IP_TFO_CLICKHOUSE=172.152.153.40
PORT_CLICKHOUSE_HTTP=8123
PORT_CLICKHOUSE_NATIVE=9000

# Redis
REDIS_VERSION=7-alpine
REDIS_PASSWORD=
REDIS_MAX_MEMORY=512mb
CONTAINER_TFO_REDIS=TFO-Platform-Redis
CONTAINER_IP_TFO_REDIS=172.152.153.50
PORT_TFO_PLATFORM_REDIS=6380

# NATS
NATS_VERSION=2-alpine
CONTAINER_TFO_NATS=TFO-Platform-NATS
CONTAINER_IP_TFO_NATS=172.152.153.55
PORT_NATS_CLIENT=4222
PORT_NATS_MONITOR=8222
